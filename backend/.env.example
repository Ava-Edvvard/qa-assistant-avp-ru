# QA-Assistant Backend Configuration
# Скопируйте этот файл в .env и заполните своими значениями:
#   cp .env.example .env

# LLM Provider: 'openai' или 'gemini'
LLM_PROVIDER=openai

# OpenAI API Key (замените на ваш реальный ключ)
# Получить: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini

# Gemini API Key (замените на ваш реальный ключ)
# Получить: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_MODEL=gemini-2.5-flash

# Server settings
HOST=127.0.0.1
PORT=8000
