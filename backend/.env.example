# QA-Assistant Backend Configuration
# Скопируйте этот файл в .env и заполните своими значениями:
#   cp .env.example .env

# LLM Provider: 'custom' (для Kaspersky LLM)
LLM_PROVIDER=custom

# API-ключ для Kaspersky LLM (или другого кастомного провайдера)
# Документация: https://confluence.kaspersky.com/spaces/LS/pages/1577822276/%F0%9F%A4%96%D0%A0%D0%B0%D0%B1%D0%BE%D1%82%D0%B0+%D1%87%D0%B5%D1%80%D0%B5%D0%B7+API
CUSTOM_API_KEY=your-api-key-here
CUSTOM_BASE_URL=https://llm.kaspersky-labs.com/v1/
CUSTOM_MODEL=yandexgpt

# Server settings
HOST=127.0.0.1
PORT=8000
